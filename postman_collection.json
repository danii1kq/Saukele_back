{
  "info": {
    "name": "Saukele API - Full Blueprint Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full Postman collection generated from blueprint/openapi.yaml for all Saukele backend endpoints"
  },
  "item": [
    {
      "name": "Auth / Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"name\": \"Tester\",\n  \"password\": \"Test12345\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('testEmail', `tester+${Date.now()}@example.com`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Tokens returned', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.accessToken).to.be.a('string');",
              "  pm.expect(json.refreshToken).to.be.a('string');",
              "  pm.collectionVariables.set('accessToken', json.accessToken);",
              "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
              "  pm.environment.set('accessToken', json.accessToken);",
              "  pm.environment.set('refreshToken', json.refreshToken);",
              "});"
            ]
          }
        }
      ]
    },

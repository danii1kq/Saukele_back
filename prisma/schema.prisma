generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  REGISTRANT
  ADMIN
}

enum RegistryStatus {
  ACTIVE
  ARCHIVED
}

enum GiftItemStatus {
  PENDING
  FUNDED
  PURCHASED
  DELIVERED
}

enum GiftItemPriority {
  HIGH
  MEDIUM
  LOW
}

enum ContributionStatus {
  PENDING
  CONFIRMED
  REFUNDED
}

enum RelationshipType {
  PARENT
  SIBLING
  CHILD
  COUSIN
  UNCLE_AUNT
  FAMILY_FRIEND
  OTHER
}

enum KinshipTier {
  CLOSE
  EXTENDED
  FRIEND
}

model User {
  id                Int            @id @default(autoincrement())
  email             String         @unique
  name              String
  passwordHash      String
  role              UserRole       @default(GUEST)
  tokenVersion      Int            @default(0)
  provider          String         @default("local")
  isVerified        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  registries        Registry[]
  contributions     Contribution[]
  refreshTokens     RefreshToken[]
  familyMembers     FamilyMember[] @relation("FamilyOwner")
  relatedInFamilies FamilyMember[] @relation("FamilyRelated")
  auditLogs         AuditLog[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
  @@index([email])
  @@index([role])
}

model Registry {
  id          Int            @id @default(autoincrement())
  userId      Int
  title       String
  coupleName  String
  weddingDate DateTime
  isPublic    Boolean        @default(false)
  shareCode   String         @unique
  status      RegistryStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner     User       @relation(fields: [userId], references: [id])
  giftItems GiftItem[]

  @@map("registries")
  @@index([userId])
  @@index([shareCode])
  @@index([status])
}

model GiftItem {
  id                 Int              @id @default(autoincrement())
  registryId         Int
  title              String
  description        String?
  imageUrl           String?
  targetAmountKzt    Decimal          @db.Decimal(12, 2)
  currentAmountKzt   Decimal          @default(0) @db.Decimal(12, 2)
  targetAmountEur    Decimal?         @db.Decimal(10, 2)
  exchangeRateAtTime Decimal?         @db.Decimal(10, 6)
  lockedAt           DateTime?
  status             GiftItemStatus   @default(PENDING)
  priority           GiftItemPriority @default(MEDIUM)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  registry      Registry       @relation(fields: [registryId], references: [id])
  contributions Contribution[]

  @@map("gift_items")
  @@index([registryId])
  @@index([status])
  @@index([registryId, status])
}

model Contribution {
  id                 Int                @id @default(autoincrement())
  giftItemId         Int
  userId             Int?
  contributorName    String
  amountKzt          Decimal            @db.Decimal(12, 2)
  amountEur          Decimal?           @db.Decimal(10, 2)
  exchangeRateAtTime Decimal            @db.Decimal(10, 6)
  lockedAtTimestamp  DateTime
  message            String?
  status             ContributionStatus @default(PENDING)
  createdAt          DateTime           @default(now())

  giftItem GiftItem @relation(fields: [giftItemId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@map("contributions")
  @@index([giftItemId])
  @@index([userId])
  @@index([giftItemId, status])
  @@index([createdAt])
}

model FamilyMember {
  id               Int              @id @default(autoincrement())
  userId           Int
  relatedUserId    Int?
  name             String
  relationshipType RelationshipType
  kinshipTier      KinshipTier
  createdAt        DateTime         @default(now())

  owner   User  @relation("FamilyOwner", fields: [userId], references: [id])
  related User? @relation("FamilyRelated", fields: [relatedUserId], references: [id])

  @@map("family_members")
  @@index([userId])
  @@index([relatedUserId])
  @@index([userId, kinshipTier])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int?
  action       String
  resourceType String
  resourceId   Int
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

model ExchangeRateSnapshot {
  id           Int      @id @default(autoincrement())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(10, 6)
  source       String
  createdAt    DateTime @default(now())

  @@map("exchange_rate_snapshots")
  @@index([fromCurrency, toCurrency])
  @@index([createdAt])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  token      String   @unique
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
  @@index([userId])
  @@index([token])
}

model VerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("verification_tokens")
  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
  @@index([userId])
  @@index([token])
}

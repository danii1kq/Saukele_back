# Database
DATABASE_URL=postgresql://user:password@localhost:5432/saukele_db?schema=public

# JWT Secrets
JWT_ACCESS_SECRET=replace-with-a-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@saukele.kz

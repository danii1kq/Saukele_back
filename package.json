{
  "name": "saukele-back",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node src/app.js",
    "dev:backend": "nodemon src/app.js",
    "dev:frontend": "http-server frontend -p 8080 -P http://localhost:4000?",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "migrate": "npx prisma migrate dev",
    "seed": "node prisma/seed.js",
    "test": "jest --runInBand",
    "test:smtp": "node scripts/verify-smtp.js",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.4",
    "express-rate-limit": "^7.0.1",
    "helmet": "^7.1.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "swagger-ui-express": "^4.6.3",
    "uuid": "^14.0.0",
    "yamljs": "^0.3.0",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^6.19.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node"
  }
}

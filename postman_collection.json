    {
      "name": "Auth / Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const accessToken = pm.collectionVariables.get('accessToken') || pm.environment.get('accessToken');",
              "if (accessToken) {",
              "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${accessToken}` });",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has user fields', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.email).to.be.a('string');",
              "  pm.expect(json.role).to.be.a('string');",
              "  pm.collectionVariables.set('userId', String(json.id));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth / Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const refreshToken = pm.collectionVariables.get('refreshToken') || pm.environment.get('refreshToken');",
              "if (!refreshToken || refreshToken.length < 10) {",
              "  throw new Error('refreshToken is missing. Run login/register first so the token is saved.');",
              "}",
              "pm.variables.set('refreshToken', refreshToken);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Logged out message', () => {",
              "  pm.expect(pm.response.json().message).to.eql('Logged out successfully');",
              "});"
            ]
          }
        }
      ]
    },
